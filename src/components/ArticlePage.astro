---
import type { Article } from '../data/content';
import { cancerArticles, drugArticles } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from './ArticleCard.astro';
import DrugTitle from './DrugTitle.astro';

interface Props { article: Article; }
const { article } = Astro.props;
const base = Astro.url.pathname.startsWith('/drugs/') ? 'drugs' : 'cancers';
const collectionPath = `/${base}/`;
const related = (base === 'drugs' ? drugArticles : cancerArticles)
  .filter((item) => item.slug !== article.slug)
  .slice(0, 2);
---
<BaseLayout title={article.title} description={article.summary}>
  <article class:list={['article-layout', base === 'drugs' && 'drug-article']}>
    <header class="article-header">
      <h1>{base === 'drugs' ? <DrugTitle title={article.title} /> : article.title}</h1>
      <p class="article-header-summary">{article.summary}</p>
    </header>

    {base === 'drugs' ? (
      <div class="drug-overview">
        <figure class="article-cover drug-cover">
          <div class="article-cover-media">
            <img src={article.heroImage.src} alt={article.heroImage.alt} />
          </div>
        </figure>
        {article.facts && (
          <dl id="drug-information" class="drug-facts" aria-label="药品信息">
            {article.facts.map((fact) => (
              <div>
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>
    ) : (
      <figure class:list={['article-cover', 'cancer-cover', `cancer-cover-${article.slug}`]}>
        <div class="article-cover-media">
          <img src={article.heroImage.src} alt={article.heroImage.alt} />
        </div>
      </figure>
    )}

    <div class="article-body">
      <div class="article-main">
        <p class="article-intro">{article.intro}</p>
        {article.sections.map((section, index) => (
          <>
            {base === 'cancers' && article.secondaryImage && index > 0 && article.sections[index - 1].imageAfter ? (
              <div class="article-media-split">
                <figure class="article-figure">
                  <img src={article.secondaryImage.src} alt={article.secondaryImage.alt} />
                </figure>
                <section class="article-section article-section-in-split">
                  <h2>{section.heading}</h2>
                  <div class="article-section-content">
                    {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
                    {section.bullets && <ul>{section.bullets.map((item) => <li>{item}</li>)}</ul>}
                  </div>
                </section>
              </div>
            ) : (
              <section class="article-section">
                <h2>{section.heading}</h2>
                <div class="article-section-content">
                  {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
                  {section.bullets && <ul>{section.bullets.map((item) => <li>{item}</li>)}</ul>}
                </div>
              </section>
            )}
            {base !== 'cancers' && section.imageAfter && article.secondaryImage && (
              <figure class="article-figure">
                <img src={article.secondaryImage.src} alt={article.secondaryImage.alt} />
              </figure>
            )}
          </>
        ))}
        <section class="question-panel">
          <h2>就诊问题</h2>
          <ol>{article.questions.map((question) => <li>{question}</li>)}</ol>
          {base === 'drugs' && <a class="button article-inquiry-button" href="/contact/#drug-inquiry">微信询药 <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>}
        </section>
      </div>
    </div>
  </article>

  <div class="section-muted">
    <section class="section inner related-section">
      <div class="section-heading compact-heading">
        <div><h2>相关内容</h2></div>
        <a class="text-link" href={collectionPath}>返回{base === 'drugs' ? '药物资讯' : '癌症知识'} <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </div>
      <div class="article-grid related-grid">{related.map((item) => <ArticleCard article={item} base={base} />)}</div>
    </section>
  </div>
</BaseLayout>
