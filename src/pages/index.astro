---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { featuredCancerSlugs, featuredDrugSlugs } from '../data/content';
import { getCancerArticles, getDrugArticles } from '../lib/directus';
const drugs = await getDrugArticles();
const cancers = await getCancerArticles();
const pickArticles = <T extends { slug: string }>(articles: T[], slugs: readonly string[]) =>
  slugs.flatMap((slug) => {
    const article = articles.find((item) => item.slug === slug);
    return article ? [article] : [];
  });
const featuredDrugs = pickArticles(drugs, featuredDrugSlugs);
const featuredCancers = pickArticles(cancers, featuredCancerSlugs);
---
<BaseLayout title="香港药物资讯、癌症治疗与第二诊疗意见" description="港医桥/HK CareBridge 提供香港药物资讯、癌症诊断与治疗资料，以及第二诊疗意见信息。">
  <section class="hero">
    <div class="hero-copy">
      <h1><span class="hero-title-line">香港药物资讯</span><span class="hero-title-line">癌症治疗</span><span class="hero-title-line">与第二诊疗意见</span></h1>
      <p>香港药物名称、适应证和风险资料，常见癌症的诊断与治疗信息，以及香港医生第二诊疗意见的所需资料。</p>
      <div class="hero-actions">
        <a class="button" href="/contact/#drug-inquiry">微信询药 <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>
        <a class="button button-secondary" href="/contact/#general-consultation">微信咨询</a>
      </div>
    </div>
    <aside class="hero-drug-panel" aria-label="精选药物资讯">
      <div class="hero-panel-heading"><h2>药物资讯</h2><a href="/drugs/">查看全部 <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div>
      <div class="hero-drug-list">
        {featuredDrugs.map((article) => (
          <article class="hero-drug-item">
            <a class="hero-drug-image" href={`/drugs/${article.slug}/`}><img src={article.heroImage.src} alt={article.heroImage.alt} /></a>
            <div><h3><a href={`/drugs/${article.slug}/`}>{article.title}</a></h3><p>{article.summary}</p><a class="hero-drug-link" href={`/drugs/${article.slug}/`}>药物详情 <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div>
          </article>
        ))}
      </div>
    </aside>
  </section>

  <div class="section-muted"><section class="section inner" id="drug-resources">
    <div class="section-heading"><div><h2>药物资讯</h2></div><div class="section-side"><p>药物作用、适应证、剂型、不良反应、警示症状及治疗监测资料。</p><a class="text-link" href="/drugs/">查看全部药物 <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div></div>
    <div class="article-grid">{featuredDrugs.map((article) => <ArticleCard article={article} base="drugs" />)}</div>
    <div class="section-actions"><a class="button" href="/contact/#drug-inquiry">微信询药 <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a></div>
  </section></div>

  <section class="section" id="second-opinion">
    <div class="process-feature second-opinion-feature">
      <div class="second-opinion-media">
        <img src="/images/second-opinion-record-review.jpg" alt="按对照方式整理的影像、病理与医疗资料" />
      </div>
      <div class="process-copy">
        <h2>第二诊疗意见</h2>
        <p>诊断、治疗时间线、现有资料与需要医生回答的问题。</p>
        <ul class="result-list">
          <li><strong>病情概况</strong><span>诊断、检查、治疗和病情变化的时间记录。</span></li>
          <li><strong>资料清单</strong><span>病理、影像、检测与治疗记录清单。</span></li>
          <li><strong>就诊问题</strong><span>需要医生回答的问题清单。</span></li>
        </ul>
        <a class="button button-light" href="/second-opinion/">第二诊疗意见资料 <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </div>
    </div>
  </section>

  <div class="section-muted"><section class="section inner" id="cancer-knowledge">
    <div class="section-heading"><div><h2>癌症知识</h2></div><div class="section-side"><p>各癌种的病理、分期、检查、生物标志物及治疗概念。</p><a class="text-link" href="/cancers/">查看全部癌种 <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div></div>
    <div class="article-grid">{featuredCancers.map((article) => <ArticleCard article={article} base="cancers" />)}</div>
  </section></div>

  <section class="section" id="wechat-consultation">
    <div class="process-feature consultation-feature">
      <div class="consultation-media"><img src="/images/hero-doctor-consultation.jpg" alt="医生向患者和家属讲解医疗资料，桌面放有立体癌症标志摆件" /></div>
      <div class="process-copy">
        <h2>微信咨询</h2>
        <p>文字概况、信息确认和资料整理的联系流程。</p>
        <ol class="steps">
          <li><span>01</span><div><strong>微信咨询</strong><small>咨询主题与主要问题。</small></div></li>
          <li><span>02</span><div><strong>文字概况</strong><small>诊断、治疗经过和需要回答的问题。</small></div></li>
          <li><span>03</span><div><strong>信息确认</strong><small>现有信息和待补信息。</small></div></li>
          <li><span>04</span><div><strong>整理内容</strong><small>病情摘要框架、资料清单和就诊问题清单。</small></div></li>
        </ol>
        <a class="button button-light" href="/contact/#general-consultation">微信咨询 <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </div>
    </div>
  </section>
</BaseLayout>
