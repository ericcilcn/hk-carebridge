---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCancerArticles, getDrugArticles } from '../lib/directus';
const drugs = await getDrugArticles();
const cancers = await getCancerArticles();
---
<BaseLayout title="香港药物资讯、癌症治疗与第二诊疗意见" description="港医桥/HK CareBridge 提供香港药物资讯、癌症诊断与治疗资料，以及第二诊疗意见信息。">
  <section class="hero">
    <div class="hero-copy">
      <h1><span class="hero-title-line">香港药物资讯</span><span class="hero-title-line">癌症治疗</span><span class="hero-title-line">与第二诊疗意见</span></h1>
      <p>涵盖香港药物、癌症诊断与治疗、第二诊疗意见等资料。药物使用和第二诊疗意见由香港注册医生结合具体情况评估。</p>
      <div class="hero-actions">
        <a class="button" href="/contact/">微信咨询 <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>
        <a class="button button-secondary" href="/drugs/">查看药物资讯</a>
      </div>
    </div>
    <div class="hero-media" aria-label="医生讲解与医疗资料视觉">
      <img class="image-main" src="/images/hero-doctor-consultation.jpg" alt="医生向患者和家属讲解医疗资料，桌面放有立体癌症标志摆件" />
      <img class="image-detail" src="/images/hero-medical-reference.jpg" alt="透明资料夹内整理有癌症结构示意、药物与供复核的医疗资料" />
      <div class="index-tabs" aria-hidden="true"><span></span><span></span><span></span></div>
    </div>
  </section>

  <div class="section-muted"><section class="section inner" id="drug-resources">
    <div class="section-heading"><div><h2>药物资讯</h2></div><div class="section-side"><p>药物作用、适应证、剂型、不良反应、警示症状及治疗监测资料。</p><a class="text-link" href="/drugs/">查看全部药物 <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div></div>
    <div class="article-grid">{drugs.map((article) => <ArticleCard article={article} base="drugs" />)}</div>
  </section></div>

  <section class="section" id="second-opinion">
    <div class="process-feature second-opinion-feature">
      <div class="second-opinion-media">
        <img src="/images/second-opinion-record-review.jpg" alt="按对照方式整理的影像、病理与医疗资料" />
      </div>
      <div class="process-copy">
        <h2>第二诊疗意见</h2>
        <p>诊断、治疗时间线、现有资料与需要医生回答的问题。</p>
        <ul class="result-list">
          <li><strong>病情概况</strong><span>诊断、检查、治疗和病情变化的时间记录。</span></li>
          <li><strong>资料清单</strong><span>病理、影像、检测与治疗记录清单。</span></li>
          <li><strong>就诊问题</strong><span>需要医生回答的问题清单。</span></li>
        </ul>
        <a class="button button-light" href="/second-opinion/">第二诊疗意见资料 <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </div>
    </div>
  </section>

  <div class="section-muted"><section class="section inner" id="cancer-knowledge">
    <div class="section-heading"><div><h2>癌症知识</h2></div><div class="section-side"><p>各癌种的病理、分期、检查、生物标志物及治疗概念。</p><a class="text-link" href="/cancers/">查看全部癌种 <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div></div>
    <div class="article-grid">{cancers.map((article) => <ArticleCard article={article} base="cancers" />)}</div>
  </section></div>

  <section class="section" id="wechat-consultation">
    <div class="section-heading"><div><h2>微信咨询</h2></div><p>微信咨询流程包括文字概况、信息确认与整理内容。</p></div>
    <div class="process-overview">
      <ol class="process-cards">
        <li><span>01</span><strong>微信咨询</strong><p>咨询主题与主要问题。</p></li>
        <li><span>02</span><strong>提交文字概况</strong><p>诊断、治疗经过和主要问题的文字概况。</p></li>
        <li><span>03</span><strong>信息确认</strong><p>现有信息与待补信息的核对。</p></li>
        <li><span>04</span><strong>整理内容</strong><p>病情摘要框架、资料清单和就诊问题清单。</p></li>
      </ol>
      <div class="process-cta"><p>咨询步骤、联系信息、文字概况和整理内容。</p><a class="button" href="/contact/">微信咨询 <i class="ph ph-arrow-right" aria-hidden="true"></i></a></div>
    </div>
  </section>
</BaseLayout>
