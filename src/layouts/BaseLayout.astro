---
import '@phosphor-icons/web/regular';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
interface Props { title: string; description?: string; }
const { title, description = '港医桥/HK CareBridge，香港医疗信息与就医准备。' } = Astro.props;
const fullTitle = `${title}｜港医桥/HK CareBridge`;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f1e8" />
    <meta name="application-name" content="港医桥" />
    <meta name="apple-mobile-web-app-title" content="港医桥" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">跳到主要内容</a>
    <div class="site-shell"><Header /><main id="main"><slot /></main><Footer /></div>
  </body>
</html>
